{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Compromise Change Request",
  "type": "object",
  "required": [
    "change_id",
    "title",
    "reason",
    "affected_artifacts",
    "impact",
    "decision",
    "required_adr",
    "acceptance_evidence"
  ],
  "properties": {
    "change_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "affected_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "impact": {
      "type": "object"
    },
    "decision": {
      "enum": [
        "PROPOSED",
        "ACCEPTED",
        "REJECTED",
        "SUPERSEDED"
      ]
    },
    "required_adr": {
      "type": "boolean"
    },
    "acceptance_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
